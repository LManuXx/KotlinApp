<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Estado cuando el botón está presionado -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="45"
                android:startColor="@color/buttonPressedStart"
                android:endColor="@color/buttonPressedEnd"
                android:type="linear"/>
            <corners android:radius="30dp"/>
            <stroke android:width="3dp" android:color="@color/buttonBorder"/>
            <padding android:left="16dp" android:right="16dp"/>
        </shape>
    </item>

    <!-- Estado normal del botón -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="45"
                android:startColor="@color/buttonGradientStart"
                android:endColor="@color/buttonGradientEnd"
                android:type="linear"/>
            <corners android:radius="30dp"/>
            <stroke android:width="3dp" android:color="@color/buttonBorder"/>
            <padding android:left="16dp" android:right="16dp"/>
            <shadow android:radius="10dp" android:color="@color/buttonShadow"/>
        </shape>
    </item>
</selector>
