<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_gradient"
    tools:context=".SecondActivity">

    <TextView
        android:id="@+id/text_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ubicación: No disponible"
        android:textColor="@color/textPrimary"
        android:textSize="20sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:padding="16dp"
        app:layout_constraintBottom_toTopOf="@id/button_get_location"/>

    <Button
        android:id="@+id/button_get_location"
        android:layout_width="220dp"
        android:layout_height="60dp"
        style="@style/ModernButton"
        android:text="Obtener Ubicación"
        app:layout_constraintBottom_toTopOf="@id/button_return"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_location"/>

    <Button
        android:id="@+id/button_return"
        android:layout_width="160dp"
        android:layout_height="60dp"
        style="@style/ModernButton"
        android:text="Regresar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/button_get_location"/>

</androidx.constraintlayout.widget.ConstraintLayout>
